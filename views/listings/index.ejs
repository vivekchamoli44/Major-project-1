<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Wanderhub</title>
</head>
<body>
        <h3>All listings</h3>
        <form action="/listings/new"><button>Create new listing</button></form>
        <ul>
        <%for(listing of allListings){%>
            <li><a href="/listings/<%=listing._id%>"><%=listing.title%></a></li>
        <%}%>
        </ul>

</body>
</html>
