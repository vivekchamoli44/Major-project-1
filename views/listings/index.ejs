<% layout("/layouts/boilerplate")%>
<body>
        <h3>All listings</h3>
        <!-- <form action="/listings/new"><button>Create new listing</button></form> -->
        <div class="row row-cols-lg-3 row-cols-md-2 row-cols-sm-1 ">
            <%for(listing of allListings){%>
                <a href="/listings/<%=listing._id%>" class="listing-link">
                    <div class="card listing-card col" >
            <img src="<%=listing.image%>" class="card-img-top" alt="listing image" style="height: 20rem;">
            <div class="card-img-overlay">Wanderhub</div>
            <div class="card-body">
                <p class="card-text">
                    <b><%=listing.title%></b><br>
                    &#8377; <%=listing.price.toLocaleString("en-IN")%>/night
                </p>
            </div>
        </div>
                </a>
         
        <%}%>
        </div>
</body>
